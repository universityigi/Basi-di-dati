/* Calcolare il nome dei giocatori che non hanno mai giocato nel 2015. */\
\
select g1.nome\
from giocatore g1\
where g1 not in (select g1 from giocatore g1, partita p where p.codvincente = g1.codice and p.anno = 2015) and g1 not in (select g2 from giocatore g2, partita p where p.codperdente=g2.codice and p.anno = 2015)\
\
