/*\
Per ogni giocatore G1 e per ogni partita P in cui G1 `e risultato vincitore sconfiggendo con almeno\
due set di scarto un giocatore G2 di categoria superiore a quella di G1, restituire il nome di G1,\
il nome di G2, il numero della partita P e l\'92anno in cui la partita P si `e giocata. */\
\
select g1.nome, g2.nome, count(p), p.anno\
from giocatore g1, giocatore g2, partita p\
where p.setvintig1 -2 >= p.setvintig2 and p.codvincente = g1.codice and p.codperdente=g2.codice and g1.categoria<g2.categoria\
group by g1.nome, g2.nome, p.anno \
