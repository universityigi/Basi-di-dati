1)  select p.nome, regione
    from persona p, citta
    where eta > 17 and p.cittaNascita = citta.nome
    
2)  select p.nome, f.nome
    from persona p,persona f, genia g
    where p.nome = g.genitore and f.nome = g.figlio and p.cittaNascita = f.cittaNascita

3)  select distinct regione
    from persona p, genia, citta
    where p.nome = genia.genitore and p.cittaNascita = citta.nome and p.eta >50

4)  select distinct p.nome
    from persona p, genia f left join genia n on f.genitore = n.figlio
    where p.nome = n.genitore and p.sesso = 'M'
    
5)  select f.figlio,figlio.eta,n.genitore as nonno
    from persona figlio,genia f left join genia n on f.genitore = n.figlio
    where figlio.nome = f.figlio and n.genitore not in (select distinct p.nome
                                                        from persona p, genia f left join genia n on f.genitore = n.figlio
                                                        where p.nome = n.genitore and p.sesso = 'F')
                                                        
                                                        
                                                        
